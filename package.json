{
  "name": "belcreation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:types": "pnpm payload generate:types",
    "generate:importmap": "pnpm payload generate:importmap",
    "seed:faqs": "tsx --env-file=.env.local scripts/seed-faqs.ts",
    "seed:activities": "tsx --env-file=.env.local scripts/seed-activities.ts",
    "seed:shifts": "tsx --env-file=.env.local scripts/seed-shifts.ts",
    "seed:plans": "tsx --env-file=.env.local scripts/seed-plans.ts",
    "seed:team": "tsx --env-file=.env.local scripts/seed-team-members.ts",
    "seed:lodges": "tsx --env-file=.env.local scripts/seed-lodges.ts"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "^3.83.0",
    "@payloadcms/next": "^3.83.0",
    "@payloadcms/plugin-seo": "^3.83.0",
    "@payloadcms/richtext-lexical": "^3.83.0",
    "@payloadcms/storage-vercel-blob": "^3.83.0",
    "graphql": "^16.13.2",
    "next": "16.2.4",
    "payload": "^3.83.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
