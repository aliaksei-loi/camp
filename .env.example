# MongoDB Atlas — provisioned via Vercel Atlas integration
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/belcreation

# Payload secret — generate with: openssl rand -base64 32
PAYLOAD_SECRET=change-me-use-openssl-rand-base64-32

# Vercel Blob — generated in Vercel dashboard (Storage → Blob → Create store)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# Preview mode secret — generate with: openssl rand -base64 32
PREVIEW_SECRET=change-me-use-openssl-rand-base64-32

# Google Sheets webhook (Apps Script Web App) for /api/booking
# 1. In your Google Sheet: Extensions → Apps Script → paste the snippet
#    from scripts/sheets-webhook.gs, set SHARED_SECRET to match below
# 2. Deploy → New deployment → Web app → Execute as: Me, Access: Anyone
# 3. Copy the deployment URL into SHEETS_WEBHOOK_URL
# 4. Generate a fresh secret: openssl rand -base64 24
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
SHEETS_WEBHOOK_SECRET=change-me-use-openssl-rand-base64-24
