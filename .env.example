# MongoDB Atlas — provisioned via Vercel Atlas integration
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/belcreation

# Payload secret — generate with: openssl rand -base64 32
PAYLOAD_SECRET=change-me-use-openssl-rand-base64-32

# Vercel Blob — generated in Vercel dashboard (Storage → Blob → Create store)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# Preview mode secret — generate with: openssl rand -base64 32
PREVIEW_SECRET=change-me-use-openssl-rand-base64-32
